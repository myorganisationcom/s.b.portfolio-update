generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Blog {
  id            BigInt   @id @default(autoincrement())
  title         String
  seoSlug       String   @unique @map("seo_slug")
  status        String
  views         BigInt   @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  content       String
  author        String
  featuredImage String   @map("featured_image")
  tags          String
  categoryId    BigInt   @map("category_id")
  downloadLink  String?  @map("download_link")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("blogs")
}

model CaseStudy {
  id              BigInt   @id @default(autoincrement())
  title           String
  seoSlug         String   @unique @map("seo_slug")
  status          String   @default("draft")
  industry        String
  duration        String
  clientName      String   @default("") @map("client_name")
  introText       String   @map("intro_text")
  challenges      String
  solutions       String
  results         String
  quoteText       String   @default("") @map("quote_text")
  quoteAuthor     String   @default("") @map("quote_author")
  featuredImage   String   @default("") @map("featured_image")
  tags            String   @default("")
  views           BigInt   @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("case_studies")
}

model Lead {
  id           BigInt   @id @default(autoincrement())
  name         String
  organisation String   @default("")
  designation  String   @default("")
  email        String
  phone        String
  quizAnswers  String   @default("{}") @map("quiz_answers")
  leadQuality  String   @default("Nurture") @map("lead_quality")
  healthScore  Int      @default(0) @map("health_score")
  bottleneck   String   @default("") @map("bottleneck")
  aiAnalysis   String   @default("") @map("ai_analysis")
  pdfPath      String   @default("") @map("pdf_path")
  callStatus   String   @default("New") @map("call_status")
  notes        String?
  source       String   @default("modal")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("leads")
}

model AuditSubmission {
  id             BigInt   @id @default(autoincrement())

  // Stage 1 — Contact
  name           String
  designation    String   @default("")
  organisation   String   @default("")
  email          String
  phone          String
  whatsapp       String   @default("")
  city           String   @default("")
  website        String   @default("")

  // Stage 2 — Business Audit (JSON)
  auditData      String   @default("{}") @map("audit_data")

  // Stage 3 — Diagnosis (JSON)
  diagnosisData  String   @default("{}") @map("diagnosis_data")

  // Scoring & AI
  leadScore      Int      @default(0) @map("lead_score")
  leadQuality    String   @default("Nurture") @map("lead_quality")
  bottleneck     String   @default("")
  aiAnalysis     String   @default("") @map("ai_analysis")
  pdfPath        String   @default("") @map("pdf_path")

  // CRM
  callStatus     String   @default("New") @map("call_status")
  notes          String?

  createdAt      DateTime @default(now()) @map("created_at")

  @@map("audit_submissions")
}

model AdminUser {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model FormSubmission {
  id             BigInt   @id @default(autoincrement())
  formType       String   @map("form_type")
  name           String
  email          String?
  phone          String?
  organisation   String?
  designation    String?
  businessStage  String?  @map("business_stage")
  goals          String?
  businessType   String?  @map("business_type")
  revenue        String?
  challenge      String?
  otherChallenge String?  @map("other_challenge")
  investment     String?
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("form_submissions")
}
